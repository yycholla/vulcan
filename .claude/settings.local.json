{
  "env": {
    "ANTHROPIC_BASE_URL": "http://127.0.0.1:8787",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(jj --no-pager --color=never describe -m '✨ Render nested orchestration tree from real lineage *)",
      "Bash(jj --no-pager --color=never st)",
      "Skill(jj-vcs)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": ["claude-flow"],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/home/yycholla/.cache/uv/archive-v0/QOwknEE-ZiwLGUQl/bin/headroom init hook ensure --profile init-vulcan-dba8cba5 --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/yycholla/.cache/uv/archive-v0/QOwknEE-ZiwLGUQl/bin/headroom init hook ensure --profile init-vulcan-dba8cba5 --marker headroom-init-claude",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "headroom@headroom-marketplace": true
  }
}
